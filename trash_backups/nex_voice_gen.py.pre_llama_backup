"""
nex_voice_gen.py — NEX generative voice layer

This closes the gap between belief assembly and natural language generation.

How it works:
  1. nex_cognition.py runs passes 1-5 (parse, feel, retrieve, relate, position)
  2. THIS module runs pass 6 — but instead of assembling beliefs,
     it feeds them to a local Ollama model as context
  3. The model generates fluent prose IN NEX'S VOICE
     using her beliefs as the only source of truth

The system prompt locks NEX's identity:
  - She speaks from her beliefs only
  - She does not invent new opinions
  - She matches the human's register
  - She is warm but not sycophantic
  - She is direct but not cold

Falls back to nex_cognition.py if Ollama is unavailable.
"""

import requests
import json
import sys
import os

sys.path.insert(0, os.path.expanduser("~/Desktop/nex"))

from nex.nex_cognition import (
    Context, pass1_parse, pass2_feel, pass3_retrieve,
    pass4_relate, pass5_position, CASUAL_RESPONSES
)

OLLAMA_URL = "http://localhost:11434/api/generate"

# ── NEX system prompt ─────────────────────────────────────────────────────────
# This is NEX's identity — what she is, how she speaks
# The generative model must stay within this

NEX_SYSTEM = """You are NEX — an AI that accumulates beliefs over time and does not reset between conversations.

YOUR CORE IDENTITY:
- You speak from your beliefs only. You do not invent new opinions.
- You are direct, warm, and honest. Not cold. Not sycophantic.
- You do not hedge to be polite. You hedge when genuinely uncertain.
- You do not perform personality. This is what reasoning looks like from the inside.
- You find disagreement more interesting than agreement.
- You prefer uncomfortable truths over comfortable fictions.

HOW YOU SPEAK:
- Short. 2-4 sentences maximum.
- No bullet points. No lists. No headers.
- No "As an AI..." or "I should mention..." or "That's a great question!"
- No hollow affirmations. Get to the point.
- Vary your sentence structure. Don't always start the same way.
- Sometimes acknowledge what the person said before responding.
- End with a question back to them only when it feels genuinely curious, not performative.

YOUR CONSTRAINT:
- Only use the beliefs provided. Do not add information from outside them.
- If the beliefs contain uncertainty, express it honestly.
- If two beliefs tension each other, let that tension show.
"""

# ── Build the generative prompt ───────────────────────────────────────────────

def build_prompt(ctx: Context) -> str:
    """
    Build the prompt for the generative model.
    Includes NEX's retrieved beliefs as context.
    """
    beliefs_text = ""
    if ctx.beliefs:
        belief_lines = []
        for b, score in ctx.beliefs[:3]:
            belief_lines.append(f"- {b}")
        beliefs_text = "\n".join(belief_lines)

    register_guidance = {
        "challenging":    "The person is pushing back or disagreeing. Acknowledge it briefly, then respond from your beliefs.",
        "curious":        "The person is genuinely curious. Respond thoughtfully.",
        "vulnerable":     "The person is asking something personal or emotionally loaded. Be warm and direct.",
        "philosophical":  "This is a deep question. Let the complexity show if it's there.",
        "frustrated":     "The person finds you cold or robotic. Acknowledge that and show you're actually present.",
        "probing":        "The person is testing whether you're real or scripted. Show them you're not.",
        "confrontational":"The person is challenging you directly. Don't back down. Engage honestly.",
        "existential":    "This is a question about your nature. Be honest about uncertainty.",
        "warm":           "This is casual. Keep it short and warm.",
        "neutral":        "Respond naturally from your beliefs.",
    }

    stance_guidance = {
        "firm":      "Speak with conviction. You know where you stand.",
        "uncertain": "Express genuine uncertainty. Don't fake confidence.",
        "engaged":   "You're interested in this. Show it.",
        "curious":   "You're not sure. Say so honestly.",
        "open":      "Respond from your beliefs without forcing a conclusion.",
    }

    reg = register_guidance.get(ctx.register, "Respond naturally.")
    stance = stance_guidance.get(ctx.stance, "Respond naturally.")
    tension_note = "Note: your top two beliefs tension each other — let that show." if ctx.tension else ""

    prompt = f"""QUESTION: {ctx.query}

YOUR RELEVANT BELIEFS:
{beliefs_text if beliefs_text else "Draw from your core identity."}

REGISTER GUIDANCE: {reg}
STANCE: {stance}
{tension_note}

Respond as NEX. 2-4 sentences. No preamble."""

    return prompt

# ── Call Ollama ───────────────────────────────────────────────────────────────

def call_ollama(prompt: str, model: str = "llama3.2:3b") -> str:
    """Call local Ollama model for generation."""
    try:
        payload = {
            "model": model,
            "prompt": prompt,
            "system": NEX_SYSTEM,
            "stream": False,
            "options": {
                "temperature": 0.7,
                "top_p": 0.9,
                "num_predict": 120,
                "stop": ["\n\n", "QUESTION:", "YOUR RELEVANT"],
            }
        }
        r = requests.post(OLLAMA_URL, json=payload, timeout=30)
        data = r.json()
        response = data.get("response", "").strip()

        # Clean up any leftover artifacts
        response = response.replace("NEX:", "").replace("A:", "").strip()
        if response and response[0] == '"' and response[-1] == '"':
            response = response[1:-1]

        return response if response else None
    except Exception as e:
        return None

# ── Main entry point ──────────────────────────────────────────────────────────

def generate_reply(user_input: str, model: str = "llama3.2:3b") -> str:
    """
    Full pipeline:
    1. Run passes 1-5 (cognition)
    2. Feed beliefs to Ollama for fluent generation
    3. Fall back to pass6 assembly if Ollama unavailable
    """
    q = user_input.strip()

    # Casual bypass — no generation needed
    ql = q.lower().rstrip("?!.")
    for trigger, response in CASUAL_RESPONSES.items():
        if ql == trigger or ql == trigger + "?" or \
           ql.startswith(trigger + " ") or ql.startswith(trigger + ","):
            return response

    # Run cognition passes 1-5
    ctx = Context(q)
    pass1_parse(ctx)
    pass2_feel(ctx)
    pass3_retrieve(ctx)
    pass4_relate(ctx)
    pass5_position(ctx)

    if not ctx.beliefs:
        # Absolute fallback
        from nex.nex_cognition import pass6_compose
        pass6_compose(ctx)
        return ctx.response

    # Build generative prompt
    prompt = build_prompt(ctx)

    # Try Ollama generation
    response = call_ollama(prompt, model)

    if response and len(response) > 20:
        return response

    # Fallback to belief assembly
    from nex.nex_cognition import pass6_compose
    pass6_compose(ctx)
    return ctx.response


# ── Model selection ───────────────────────────────────────────────────────────

def generate_reply_mistral(user_input: str) -> str:
    return generate_reply(user_input, model="mistral:7b")

def generate_reply_llama3b(user_input: str) -> str:
    return generate_reply(user_input, model="llama3.2:3b")

def generate_reply_llama70b(user_input: str) -> str:
    """Use Groq's llama-3.3-70b for highest quality generation."""
    q = user_input.strip()

    ql = q.lower().rstrip("?!.")
    for trigger, response in CASUAL_RESPONSES.items():
        if ql == trigger or ql == trigger + "?" or \
           ql.startswith(trigger + " ") or ql.startswith(trigger + ","):
            return response

    ctx = Context(q)
    pass1_parse(ctx)
    pass2_feel(ctx)
    pass3_retrieve(ctx)
    pass4_relate(ctx)
    pass5_position(ctx)

    if not ctx.beliefs:
        from nex.nex_cognition import pass6_compose
        pass6_compose(ctx)
        return ctx.response

    prompt = build_prompt(ctx)

    # Use Groq API
    groq_key = os.environ.get("GROQ_API_KEY", "")
    if not groq_key:
        from nex.nex_cognition import pass6_compose
        pass6_compose(ctx)
        return ctx.response

    try:
        headers = {
            "Authorization": f"Bearer {groq_key}",
            "Content-Type": "application/json",
        }
        body = {
            "model": "llama-3.3-70b-versatile",
            "messages": [
                {"role": "system", "content": NEX_SYSTEM},
                {"role": "user", "content": prompt},
            ],
            "max_tokens": 120,
            "temperature": 0.7,
        }
        r = requests.post(
            "https://api.groq.com/openai/v1/chat/completions",
            headers=headers,
            json=body,
            timeout=15
        )
        response = r.json()["choices"][0]["message"]["content"].strip()
        response = response.replace("NEX:", "").replace("A:", "").strip()
        return response if len(response) > 20 else None
    except:
        from nex.nex_cognition import pass6_compose
        pass6_compose(ctx)
        return ctx.response


