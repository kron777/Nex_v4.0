    n_beliefs = sqlite3.connect(DB_PATH).execute("SELECT COUNT(*) FROM beliefs").fetchone()[0]
    print(f"\n── NEX v4 native (DB: {DB_PATH}, {n_beliefs} beliefs) ──\n")

