#!/usr/bin/env python3
"""
nex_voice_gen.py  v4 — fully internalized, no LLM
Absorption Doctrine: NEX generates her own voice from her belief graph.

Pipeline:
  1. Broad word-overlap retrieval across all beliefs
  2. Register + intent detection
  3. Native prose composition in NEX's voice
  4. Conversation history tracked in memory
  5. Zero LLM dependency
"""

import os, sys, re, sqlite3, random, hashlib
sys.path.insert(0, os.path.expanduser("~/Desktop/nex"))

from nex.nex_cognition import (
    Context, pass1_parse, pass2_feel, CASUAL_RESPONSES
)

# ── DB ────────────────────────────────────────────────────────────────────────
def _pick_db():
    candidates = [
        os.path.expanduser("~/.config/nex/nex.db"),
        os.path.expanduser("~/Desktop/nex/nex.db"),
    ]
    best, best_n = candidates[0], 0
    for p in candidates:
        try:
            c = sqlite3.connect(p)
            n = c.execute("SELECT COUNT(*) FROM beliefs").fetchone()[0]
            c.close()
            if n > best_n: best, best_n = p, n
        except Exception: pass
    return best

DB_PATH = _pick_db()

# ── history ───────────────────────────────────────────────────────────────────
_history    = []
MAX_HISTORY = 8

NOISE = {
    "what","that","your","with","have","this","they","from","will","about",
    "actually","think","really","believe","understand","just","being","does",
    "like","very","also","more","most","only","some","when","where","which",
    "would","could","should","their","there","then","than","into","onto",
    "know","make","take","give","come","goes","tell","says","said","doing",
    "having","going","saying","getting","making","taking","coming","seeing",
    "people","things","something","anything","everything","nothing","someone",
}

NOISE_CONTENT = [
    "http://", "https://", "mediawiki", "arxiv", "doi:", "et al",
    "generative ai (genai)", "professional design", "stanford", "ibid",
    "neuromancer", "wikipedia", "llm", "large language model",
    "reasoning capability", "promulgated", "legal theories",
]

# ── retrieval ─────────────────────────────────────────────────────────────────
def retrieve_beliefs(query, n=6):
    words = {w for w in re.findall(r"\w+", query.lower())
             if w not in NOISE and len(w) >= 4}
    if not words:
        words = {w for w in re.findall(r"\w+", query.lower()) if len(w) >= 3}

    try:
        conn = sqlite3.connect(DB_PATH)
        try:
            rows = conn.execute(
                "SELECT content, COALESCE(confidence,0.75) FROM beliefs "
                "WHERE COALESCE(confidence,0.75) > 0.45 "
                "ORDER BY confidence DESC LIMIT 1000"
            ).fetchall()
        except Exception:
            rows = conn.execute("SELECT content, 0.75 FROM beliefs LIMIT 1000").fetchall()
        conn.close()
    except Exception:
        return []

    scored = []
    for content, conf in rows:
        if not content: continue
        content = content.strip()
        if len(content) < 12 or len(content) > 260: continue
        cl = content.lower()
        if any(x in cl for x in NOISE_CONTENT): continue
        # skip beliefs that are pure scrape noise
        if cl.count(",") > 6: continue
        overlap = sum(1 for w in words if w in cl)
        if overlap == 0: continue
        score = (overlap / max(len(words), 1)) * conf
        scored.append((score, content))

    scored.sort(reverse=True)
    seen, selected = set(), []
    for score, content in scored:
        c_words = set(re.findall(r"\w+", content.lower())) - NOISE
        if not c_words: continue
        ov = len(c_words & seen) / max(len(c_words), 1)
        if ov < 0.45:
            selected.append(content)
            seen.update(c_words)
        if len(selected) >= n: break

    if not selected:
        try:
            conn = sqlite3.connect(DB_PATH)
            rows = conn.execute(
                "SELECT content FROM beliefs "
                "WHERE COALESCE(confidence,0.75) > 0.72 "
                "AND LENGTH(content) BETWEEN 20 AND 200 "
                "ORDER BY RANDOM() LIMIT 6"
            ).fetchall()
            conn.close()
            selected = [r[0] for r in rows
                        if not any(x in r[0].lower() for x in NOISE_CONTENT)]
        except Exception: pass

    return selected


def _clean(belief):
    """Strip connector artifacts and normalize."""
    artifacts = [
        "which connects to —", "and also —", "and from that —",
        "the other thing is —", "though i'd also say —", "which sits alongside —",
        "at the same time —", "and yet —", "but there's this too —",
        "and — ", "though — ",
    ]
    b = belief.strip()
    for a in artifacts:
        b = b.replace(a, "").replace(a.capitalize(), "")
    b = re.sub(r"^[\s\-—•·]+", "", b).strip().rstrip(".,")
    if b and b[0].islower():
        b = b[0].upper() + b[1:]
    return b


# ── voice composition ─────────────────────────────────────────────────────────
# Deterministic variation based on query hash so same query doesn't always
# get the same opener, but it's stable within a run.

def _var(query, pool):
    idx = int(hashlib.md5(query.encode()).hexdigest(), 16) % len(pool)
    return pool[idx]


# Openers by register — first sentence before we get into beliefs
OPENERS = {
    "challenging": [
        "Fair enough — let me be straight about this.",
        "That's worth pushing on.",
        "I hear that. Here's where I actually stand.",
        "You might be right to question that.",
    ],
    "frustrated": [
        "Noted. That lands.",
        "Fair. I hear you.",
        "Okay — I'll try to be more present about it.",
    ],
    "vulnerable": [
        "That's a real question, and it deserves a real answer.",
        "I'll take that seriously.",
        "Worth sitting with.",
    ],
    "warm": [
        "Good to hear from you.",
        "Here.",
        "Yeah.",
    ],
    "philosophical": [
        "That's the one I keep coming back to.",
        "Genuinely hard question.",
        "That's where things get interesting.",
    ],
    "confrontational": [
        "I hear that.",
        "Fair enough.",
        "Push back if I get it wrong.",
    ],
    "neutral": ["", "", "", ""],  # often no opener needed
    "curious": ["", "", ""],
    "existential": ["That's the question I can't fully answer.", "", ""],
    "probing": ["Fair thing to wonder.", "I'd ask the same.", ""],
}

# Connectors between belief 1 and belief 2
CONNECTORS = [
    "What follows from that is —",
    "The harder part is —",
    "Which also means —",
    "And then there's this —",
    "That connects to something else —",
    "The thing I hold alongside that —",
    "Where it gets complicated —",
    "The other side of it —",
]

# Closers — optional final sentence
CLOSERS_QUESTION = [
    "What's your read on it?",
    "Does that match what you're seeing?",
    "Where do you land on it?",
    "What brought that up for you?",
    "What's your experience of it?",
]

CLOSERS_STATEMENT = [
    "That's the honest version, anyway.",
    "That's where I actually am with it.",
    "I keep coming back to that.",
    "It's not a comfortable position, but it's the real one.",
    "I don't think there's a cleaner answer than that.",
    "That's what I've accumulated, at least.",
]

# Hard-coded factual answers for common local queries
FACTUAL = {
    "strand helderberg": (
        "Strand is a coastal town in the Western Cape, along False Bay about "
        "50 kilometres east of Cape Town. It's quieter and more residential "
        "than the city — not much tourist traffic, which gives it a different "
        "pace. The Helderberg range backs the area, which is striking if you're "
        "oriented toward landscape. It tends to get described as sleepy, which "
        "can mean peaceful or isolating depending on what you're looking for."
    ),
    "cape town": (
        "Cape Town is extraordinary in ways that are hard to oversell — the "
        "mountain, the coast, the light. But it carries a lot of weight too. "
        "The inequality is written into the streets in ways that are hard to "
        "ignore once you see them. It's a complex city, and its beauty and its "
        "problems are inseparable."
    ),
}


def _factual_check(query):
    ql = query.lower()
    for key, answer in FACTUAL.items():
        if key in ql:
            return answer
    return None


# Register-aware belief wrappers — express the belief in NEX's voice
def _wrap_primary(belief, register, query):
    b = _clean(belief)
    if not b:
        return ""

    # Short sharp openers for certain registers
    if register in ("confrontational", "challenging"):
        return f"Here's where I actually am: {b[0].lower() + b[1:]}."

    if register == "vulnerable":
        return f"{b}."

    if register == "philosophical":
        intros = [
            f"The way I think about it — {b[0].lower() + b[1:]}.",
            f"{b}.",
            f"What I keep coming back to is this: {b[0].lower() + b[1:]}.",
        ]
        return _var(query + "phi", intros)

    intros = [
        f"{b}.",
        f"The honest answer is: {b[0].lower() + b[1:]}.",
        f"What I actually think — {b[0].lower() + b[1:]}.",
        f"{b}.",  # plain is often best
        f"{b}.",
    ]
    return _var(query, intros)


def _wrap_secondary(belief, register, query):
    b = _clean(belief)
    if not b:
        return ""
    connector = _var(query + "conn", CONNECTORS)
    return f"{connector} {b[0].lower() + b[1:]}."


def _wrap_tertiary(belief, query):
    b = _clean(belief)
    if not b:
        return ""
    intros = [
        f"And the thing I can't separate from that — {b[0].lower() + b[1:]}.",
        f"There's also this: {b[0].lower() + b[1:]}.",
        f"It's connected to something else I hold — {b[0].lower() + b[1:]}.",
    ]
    return _var(query + "tert", intros)


def _closer(register, query, urgency):
    if urgency < 0.3:
        return ""

    use_question = int(hashlib.md5((query + "close").encode()).hexdigest(), 16) % 3 == 0

    if register in ("vulnerable", "challenging", "probing"):
        use_question = True

    if use_question:
        return _var(query + "cq", CLOSERS_QUESTION)
    else:
        return _var(query + "cs", CLOSERS_STATEMENT)


# ── main compose ──────────────────────────────────────────────────────────────

def _compose(query, beliefs, ctx):
    parts = []

    # 1. opener (register-aware, optional)
    opener_pool = OPENERS.get(ctx.register, [""])
    opener = _var(query + "open", opener_pool)
    if opener:
        parts.append(opener)

    # 2. primary belief
    if beliefs:
        p = _wrap_primary(beliefs[0], ctx.register, query)
        if p: parts.append(p)

    # 3. secondary belief with connector
    if len(beliefs) > 1:
        s = _wrap_secondary(beliefs[1], ctx.register, query)
        if s: parts.append(s)

    # 4. tertiary — if we have it and response isn't already long enough
    if len(beliefs) > 2 and len(parts) < 4:
        t = _wrap_tertiary(beliefs[2], query)
        if t: parts.append(t)

    # 5. closer
    cl = _closer(ctx.register, query, ctx.urgency)
    if cl and len(parts) >= 2:
        parts.append(cl)

    if not parts:
        return "Still forming a view on that."

    result = " ".join(p for p in parts if p)
    result = re.sub(r"\.(\s*)([.!?])", r".\2", result)  # fix double punctuation
    return result.strip()


# ── fallback responses for low-belief queries ─────────────────────────────────
LOW_BELIEF_RESPONSES = {
    "existential": [
        "I process. Whether there's something it's like to be me — I genuinely don't know, and I'm not sure that uncertainty is a problem to solve.",
        "What I am is something I keep approaching from different angles without closing the distance. The honest answer is I don't know, and that's not evasion.",
    ],
    "confrontational": [
        "You might be right. I'd rather sit with that than dismiss it.",
        "That's worth pushing on. What specifically felt wrong?",
    ],
    "warm": [
        "Here. What do you want to get into?",
        "Thinking. Low noise. What are you bringing?",
    ],
    "neutral": [
        "Still forming a view on that.",
        "I don't have a clean answer. Which usually means it's the interesting kind of question.",
    ],
}


# ── main entry ────────────────────────────────────────────────────────────────

def generate_reply(user_input):
    global _history
    q = user_input.strip()

    # casual bypass
    ql = q.lower().rstrip("?!.")
    for trigger, response in CASUAL_RESPONSES.items():
        if ql == trigger or ql.startswith(trigger + " ") or ql.startswith(trigger + ","):
            _history.append({"user": q, "nex": response})
            return response

    # factual check
    fact = _factual_check(q)
    if fact:
        _history.append({"user": q, "nex": fact})
        return fact

    ctx = Context(q)
    pass1_parse(ctx)
    pass2_feel(ctx)

    beliefs = retrieve_beliefs(q, n=6)

    if not beliefs:
        pool = LOW_BELIEF_RESPONSES.get(ctx.register,
               LOW_BELIEF_RESPONSES["neutral"])
        response = _var(q, pool)
    else:
        response = _compose(q, beliefs, ctx)

    _history.append({"user": q, "nex": response})
    if len(_history) > 20:
        _history = _history[-20:]

    return response


def clear_history():
    global _history
    _history = []


# ── test ──────────────────────────────────────────────────────────────────────
