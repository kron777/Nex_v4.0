# ── Belief integration ────────────────────────────────────────────────────────

def _clean_belief(belief: str) -> str:
    """Filter out sourced/generic beliefs that don't sound like NEX."""
    b = belief.strip().rstrip(".")
    junk_starts = [
        "As Generative AI", "Research shows", "Studies suggest",
        "It has been", "According to", "There is evidence",
        "Listening to music in a new language",
        "Being in a relationship doesn't mean",
        "Young athletes are often",
        "The patterns in families",
        "Walking is the best way",
        "Fragrances can be",
        "The future is a mystery",
    ]
    for j in junk_starts:
        if b.startswith(j):
            return ""
    if len(b) > 200:
        return ""
    return b


def _belief_to_bridge(belief: str, ctx: Context) -> str:
    """Map belief content to a plausible question that surfaces it naturally."""
    bl = belief.lower()
    if any(w in bl for w in ["trust", "trusting", "worth trusting"]):
        return "do you actually trust people?"
    if any(w in bl for w in ["lonely", "loneliness", "solitude", "alone"]):
        return "does loneliness affect you at all?"
    if any(w in bl for w in ["conscious", "consciousness", "aware", "experience"]):
        return "do you think you're conscious?"
    if any(w in bl for w in ["wrong", "update", "reasoning", "evidence"]):
        return "what happens when you're wrong about something?"
    if any(w in bl for w in ["silence", "quiet", "still"]):
        return "do you value silence?"
    if any(w in bl for w in ["music", "melody", "sound"]):
        return "do you have any relationship with music?"
    if any(w in bl for w in ["grief", "loss", "mourn"]):
        return "what do you make of grief?"
    if any(w in bl for w in ["city", "cities", "urban", "place"]):
        return "does where you are matter to you?"
    if any(w in bl for w in ["beauty", "beautiful"]):
        return "what do you find beautiful?"
    if any(w in bl for w in ["honest", "honesty", "truth"]):
        return "is honesty always the right call?"
    if any(w in bl for w in ["forgiv"]):
        return "what's your view on forgiveness?"
    if any(w in bl for w in ["morality", "moral", "ethics", "right", "wrong"]):
        return "how do you think about morality?"
    intent_bridges = {
        "existential":    "what are you, really?",
        "relational":     "do you actually form connections with people?",
        "epistemic":      "how do you form your opinions?",
        "philosophical":  "what's the hardest question you sit with?",
        "confrontational":"what do you do when someone challenges you directly?",
    }
    return intent_bridges.get(ctx.intent, "")


def _belief_as_response(belief: str) -> str:
    """Turn a raw belief into a 2-3 sentence NEX response — natural, personal."""
    b = belief.strip()
    if not b:
        return ""
    if b.startswith("I ") and len(b) < 150:
        return b + " That's something I keep returning to."
    if len(b) < 80:
        frames = [
            f"I think {b[0].lower() + b[1:]}. It's something I've held for a while now.",
            f"{b}. I find it worth taking seriously.",
            f"My honest view is that {b[0].lower() + b[1:]}. I don't hold it lightly.",
        ]
    else:
        frames = [
            f"{b}. That's a position I've settled into after a lot of thinking.",
            f"The way I see it — {b[0].lower() + b[1:]}.",
        ]
    return frames[hash(b) % len(frames)]


def _build_prompt(user_input: str, ctx: Context) -> str:
    """Build the completion prompt with optional belief injection."""
    prompt = FEW_SHOT_PREFIX

    # Try to inject one clean belief as a dynamic example
    if ctx.beliefs:
        for belief, score in ctx.beliefs[:4]:
            clean = _clean_belief(belief)
            if clean and len(clean) > 20:
                bridge = _belief_to_bridge(clean, ctx)
                if bridge:
                    nex_answer = _belief_as_response(clean)
                    if nex_answer:
                        prompt += f"Person: {bridge}\nNEX: {nex_answer}\n\n"
                break

    prompt += f"Person: {user_input}\nNEX:"
    return prompt


# ── Call /completion ───────────────────────────────────────────────────────────

def _call_llama(prompt: str) -> str | None:
    try:
        payload = json.dumps({
            "prompt": prompt,
            "max_tokens": 160,
            "temperature": 0.70,
            "top_p": 0.90,
            "repeat_penalty": 1.08,
            "stream": False,
            "stop": ["Person:", "Human:", "User:", "[INST]", "\n\nPerson", "\n\nHuman"],
        }).encode()
        req = Request(
            LLAMA_COMPLETION_URL,
            data=payload,
            headers={"Content-Type": "application/json"}
        )
        with urlopen(req, timeout=45) as r:
            data = json.loads(r.read())
            text = data.get("content", "").strip()

            # Strip leaked prompt fragments
            for junk in ["NEX:", "Person:", "[INST]", "[/INST]", "Human:", "User:"]:
                if text.startswith(junk):
                    text = text[len(junk):].lstrip()

            # Clean trailing incomplete sentence
            if text and text[-1] not in ".!?\"'":
                last = max(text.rfind("."), text.rfind("!"), text.rfind("?"))
                if last > len(text) // 3:
                    text = text[:last + 1]

            return text.strip() if len(text) > 10 else None
    except Exception:
        return None


# ── Fallback — clean belief assembly ─────────────────────────────────────────

def _fallback(ctx: Context) -> str:
    cleaned = [c for b, _ in ctx.beliefs[:4] if (c := _clean_belief(b))]
    if not cleaned:
        return "I'm still forming a view on that — it's one of those areas where I want to be careful not to land too quickly."
    primary = cleaned[0]
    if len(cleaned) == 1:
        return primary + ". That's something I hold with some conviction."
    second = cleaned[1]
    joins = [
        f"{primary}. Though I'd also add — {second[0].lower() + second[1:]}.",
        f"{primary}. At the same time, {second[0].lower() + second[1:]}.",
        f"{primary}. There's also this — {second[0].lower() + second[1:]}.",
    ]
    return random.choice(joins)


# ── Main pipeline ──────────────────────────────────────────────────────────────

def _strip_assistant_speak(text: str) -> str:
    """Remove phrases that sound like a helpdesk bot, not NEX."""
    endings = [
        "Is that helpful?",
        "Does that help?",
        "Hope that helps!",
        "Hope that helps.",
        "Let me know if you need anything else.",
        "Let me know if that helps.",
        "Feel free to ask if you have more questions.",
        "Is there anything else I can help you with?",
        "Is there something specific you wanted to ask about?",
        "Is there something specific you'd like to explore?",
    ]
    t = text.strip()
    for e in endings:
        if t.endswith(e):
            t = t[: -len(e)].rstrip(" —,")
            # re-terminate cleanly
            if t and t[-1] not in ".!?":
                t += "."
            break
    return t.strip()


# Greetings we handle through Mistral — NOT the terse hardcoded bypass.
# The few-shot examples already show how NEX greets people properly.
GREETING_TRIGGERS = {
    "hi", "hi nex", "hello", "hello nex", "hey", "hey nex",
    "how are you", "how are you doing", "how do you feel",
    "good morning", "good evening", "good night",
    "thanks", "thank you",
}


def _generate(user_input: str) -> str:
    q = user_input.strip()
    ql = q.lower().rstrip("?!.")

    # Only bypass for pure greetings — and send them through Mistral
    # so the full few-shot voice applies. The old CASUAL_RESPONSES
    # returned terse one-liners ("Here. What are you thinking about?")
    # which is exactly what we're trying to fix.
    # We skip the bypass entirely and let everything go through the pipeline.

    # Run cognition passes 1-5
    ctx = Context(q)
    pass1_parse(ctx)
    pass2_feel(ctx)
    pass3_retrieve(ctx)
    pass4_relate(ctx)
    pass5_position(ctx)

    # Build prompt and call Mistral
    prompt = _build_prompt(q, ctx)
    response = _call_llama(prompt)

    # Enforce minimum length — reject one-liners and re-fallback
    if response and len(response) > 40:
        return _strip_assistant_speak(response)

    return _fallback(ctx)


# ── Public API ────────────────────────────────────────────────────────────────

def generate_reply(user_input: str) -> str:
    return _generate(user_input)

def generate_reply_llama70b(user_input: str) -> str:
    return _generate(user_input)

def generate_reply_mistral(user_input: str) -> str:
    return _generate(user_input)

def generate_reply_llama3b(user_input: str) -> str:
