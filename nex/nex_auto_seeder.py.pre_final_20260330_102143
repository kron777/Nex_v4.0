"""
nex_auto_seeder.py — Autonomous Scheduled Belief Seeding
=========================================================
NEX runs her own seeder periodically to expand her belief corpus
and deepen her reasoning capacity.

Schedule:
  - Every 6 hours: small ArXiv seed (50-100 new beliefs)
  - Every 24 hours: full seed across all topics (300-150 new beliefs)
  - Triggered after: belief count drops below MIN_BELIEFS threshold

Wire into run.py REFLECT phase.
Deploy to: ~/Desktop/nex/nex/nex_auto_seeder.py
"""

import os, sys, time, json, sqlite3, threading, urllib.request, urllib.parse
