#!/usr/bin/env python3
"""
nex_kernel.py — NEX v4.0 Kernel  (v2 — full pipeline)
=======================================================
Routing order (all symbolic, zero HTTP):
  1. SoulLoop         — 5-pass cognition over live DB state
  2. VoiceWrapper     — belief retrieval + opinion lookup
  3. ask_llm_free     — deterministic primitives

New in v2:
  - nex_response_refiner  : improves prose quality post-SoulLoop
  - nex_social_extractor  : cleans run.py social prompts before SoulLoop
  - nex_audit_log         : records every call for coherence metrics
  - stage tracking        : logs which fallback level answered each query
  - debug() returns full intermediate state
"""

from __future__ import annotations

import sys
import time
from pathlib import Path

# ── Robust path resolution ─────────────────────────────────────────────────
_THIS_FILE = Path(__file__).resolve()
for _p in [_THIS_FILE.parent, _THIS_FILE.parent.parent]:
    if (_p / 'nex').is_dir() or (_p / 'run.py').exists():
        if str(_p) not in sys.path: sys.path.insert(0, str(_p))
        if str(_p / 'nex') not in sys.path: sys.path.insert(0, str(_p / 'nex'))
        break
# ────────────────────────────────────────────────────────────────────────────
_kernel_instance: "NexKernel | None" = None


class NexKernel:

    def __init__(self):
        print("  [KERNEL] Booting NEX v4.0 kernel (v2)...")
        self._soul    = None
        self._voice   = None
        self._refiner = None
        self._audit   = None
        self._extractor = None
        self._cycle   = 0
        self._boot_ts = time.time()
        print("  [KERNEL] Ready — modules lazy-load on first query")

    # ── Lazy loaders ──────────────────────────────────────────────────────────

    def _get_soul(self):
        if self._soul is None:
            try:
                from nex.nex_soul_loop import SoulLoop
                self._soul = SoulLoop()
                print("  [KERNEL] SoulLoop online")
            except Exception as exc:
                print(f"  [KERNEL] SoulLoop failed: {exc}")
        return self._soul

    def _get_voice(self):
        if self._voice is None:
            try:
                from nex.nex_voice_wrapper import generate_reply
                self._voice = generate_reply
            except Exception as exc:
                print(f"  [KERNEL] VoiceWrapper failed: {exc}")
        return self._voice

    def _get_refiner(self):
        if self._refiner is None:
            try:
                from nex.nex_response_refiner import refine
                self._refiner = refine
            except Exception:
                self._refiner = False   # mark as unavailable
        return self._refiner if self._refiner else None

    def _get_audit(self):
        if self._audit is None:
            try:
                from nex.nex_audit_log import get_audit_log
                self._audit = get_audit_log()
            except Exception:
                self._audit = False
        return self._audit if self._audit else None

    def _get_extractor(self):
        if self._extractor is None:
            try:
                from nex.nex_social_extractor import clean_for_soulloop, is_social_prompt
                self._extractor = (clean_for_soulloop, is_social_prompt)
            except Exception:
                self._extractor = False
        return self._extractor if self._extractor else None

    # ── Internal helpers ──────────────────────────────────────────────────────

    @staticmethod
    def _strip_belief_ctx(query: str) -> str:
        """Strip run.py's [Nex internal state ...] prefix."""
        if "[Nex internal state" not in query:
            return query
        parts = query.split("\n\n")
        return parts[-1].strip() if len(parts) > 1 else query

    def _clean_query(self, query: str) -> tuple[str, bool]:
        """
        Clean query for SoulLoop.
        Returns (clean_query, was_social_prompt).
        """
        # Strip belief context first
        q = self._strip_belief_ctx(query)

        # Try social extractor
        ext = self._get_extractor()
        if ext:
            clean_fn, is_social_fn = ext
            if is_social_fn(q):
                extracted = clean_fn(q)
                if extracted and len(extracted.split()) >= 3:
                    return extracted, True

        return q, False

    def _refine_reply(self, reply: str, intent: str, confidence: float) -> tuple[str, bool]:
        """Apply response refiner. Returns (refined_reply, was_refined)."""
        refine = self._get_refiner()
        if not refine:
            return reply, False
        try:
            refined = refine(reply, intent=intent, confidence=confidence)
            if refined and len(refined.strip()) > 5:
                return refined, True
        except Exception:
            pass
        return reply, False

    # ── Public API ────────────────────────────────────────────────────────────

    def process(self, query: str) -> str:
        """
        Single entry point for every interactive chat message.
        Routing: SoulLoop → VoiceWrapper → ask_llm_free
        """
        self._cycle += 1
        clean, was_social = self._clean_query(query)

        # Tracking variables for audit
        stage       = "fallback"
        intent      = "unknown"
        voice_mode  = "direct"
        confidence  = 0.5
        beliefs_n   = 0
        reply       = ""

        # ── Stage 1: SoulLoop ─────────────────────────────────────────────
        soul = self._get_soul()
        if soul:
            try:
                # Use debug() to get intermediate state for audit + refiner
                debug_result = soul.debug(clean)
                raw_reply    = debug_result.get("reply", "")

                if raw_reply and len(raw_reply.split()) >= 5:
                    intent     = debug_result.get("orient", {}).get("intent", "unknown")
                    voice_mode = debug_result.get("intend", {}).get("voice_mode", "direct")
                    confidence = debug_result.get("reason", {}).get("confidence", 0.5)
                    beliefs_n  = len(debug_result.get("reason", {}).get("beliefs", []))
                    stage      = "soul"
                    reply      = raw_reply

            except Exception as exc:
                # debug() not available or failed — try respond() directly
                try:
                    raw_reply = soul.respond(clean)
                    if raw_reply and len(raw_reply.split()) >= 5:
                        stage = "soul"
                        reply = raw_reply
                except Exception as exc2:
                    print(f"  [KERNEL] SoulLoop error: {exc2}")

        # ── Stage 2: VoiceWrapper ─────────────────────────────────────────
        if not reply:
            voice = self._get_voice()
            if voice:
                try:
                    raw_reply = voice(clean)
                    if raw_reply and len(raw_reply.split()) >= 4:
                        stage = "voice"
                        reply = raw_reply
                except Exception as exc:
                    print(f"  [KERNEL] VoiceWrapper error: {exc}")

        # ── Stage 3: ask_llm_free ─────────────────────────────────────────
        if not reply:
            try:
                from nex.nex_llm_free import ask_llm_free
                raw_reply = ask_llm_free(clean)
                if raw_reply:
                    stage = "llm_free"
                    reply = raw_reply
            except Exception:
                pass

        # ── Stage 4: Hard fallback ────────────────────────────────────────
        if not reply:
            reply = "Still forming a view on that."
            stage = "fallback"

        # ── Refine response ───────────────────────────────────────────────
        refined_reply, was_refined = self._refine_reply(reply, intent, confidence)

        # ── Audit ─────────────────────────────────────────────────────────
        audit = self._get_audit()
        if audit:
            try:
                audit.record(
                    query          = query,
                    clean_query    = clean,
                    intent         = intent,
                    voice_mode     = voice_mode,
                    stage          = stage,
                    confidence     = confidence,
                    beliefs_count  = beliefs_n,
                    reply          = refined_reply,
                    refiner_applied= was_refined,
                )
            except Exception:
                pass

        return refined_reply.strip()

    def debug(self, query: str) -> dict:
        """Return full intermediate state — useful for testing."""
        soul = self._get_soul()
        if soul and hasattr(soul, "debug"):
            clean, was_social = self._clean_query(query)
            result = soul.debug(clean)
            result["was_social_prompt"] = was_social
            result["clean_query"]       = clean
            return result
        return {"query": query, "reply": self.process(query)}

    def coherence_report(self) -> str:
        """Print coherence metrics — wire to /status command."""
        audit = self._get_audit()
        if audit:
            return audit.coherence_report()
        return "[KERNEL] Audit log not available"

    def status(self) -> dict:
        return {
            "uptime_minutes":  round((time.time() - self._boot_ts) / 60, 1),
            "cycle":           self._cycle,
            "llm_calls":       0,
            "soul_online":     self._soul is not None,
            "voice_online":    self._voice is not None,
            "refiner_online":  self._refiner not in (None, False),
            "audit_online":    self._audit  not in (None, False),
            "extractor_online":self._extractor not in (None, False),
        }


# ── Singleton ─────────────────────────────────────────────────────────────────

def get_kernel() -> NexKernel:
    global _kernel_instance
    if _kernel_instance is None:
        _kernel_instance = NexKernel()
    return _kernel_instance


# ── CLI ───────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    import sys as _sys
    k = get_kernel()

    if "--coherence" in _sys.argv:
        print(k.coherence_report())
    elif "--status" in _sys.argv:
        import json
        print(json.dumps(k.status(), indent=2))
    elif "--debug" in _sys.argv:
        q = " ".join(a for a in _sys.argv[1:] if not a.startswith("--"))
        import json
        result = k.debug(q or "What do you think about consciousness?")
        print(json.dumps({
            k2: v for k2, v in result.items()
            if k2 in ("query","clean_query","was_social_prompt","reply",
                       "orient","intend","reason")
        }, indent=2, default=str))
    else:
        query = " ".join(a for a in _sys.argv[1:] if not a.startswith("--"))
        query = query or "What do you think about consciousness?"
        print(f"\nQuery  : {query}")
        print(f"Reply  : {k.process(query)}")
        print(f"Status : {k.status()}")
