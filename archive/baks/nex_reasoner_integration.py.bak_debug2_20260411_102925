"""


# ── Standalone test ───────────────────────────────────────────────────────────

def _mock_cognite(query: str) -> str:
    """Simulate cognite() for integration testing without the full stack."""
    return f"[mock cognite response to: {query[:60]}]"


if __name__ == "__main__":
    print(PATCH_INSTRUCTIONS)

    import argparse
    ap = argparse.ArgumentParser()
    ap.add_argument("--query", type=str, default="Does consciousness require a physical substrate?")
    ap.add_argument("--mode",  type=str, default="augment", choices=["augment","override","parallel"])
    ap.add_argument("--mock",  action="store_true", help="Use mock cognite (no LLM needed)")
    args = ap.parse_args()

    INTEGRATION_MODE = args.mode

    cognite_fn = _mock_cognite if args.mock else None

    if cognite_fn is None:
        try:
            sys.path.insert(0, str(Path(__file__).parent))
            from nex.nex_cognition import cognite as cognite_fn
        except ImportError:
            print("nex_cognition not available — using mock. Run with --mock to suppress this.")
            cognite_fn = _mock_cognite

    print(f"\nQuery    : {args.query}")
    print(f"Mode     : {INTEGRATION_MODE}")
    print(f"Cognite  : {'mock' if cognite_fn is _mock_cognite else 'real'}\n")

    result = gated_cognite(args.query, cognite_fn)

    print(f"Source       : {result['source']}")
    print(f"Gate decision: {result['gate_decision']}")
    print(f"Gate score   : {result['gate_score']:.3f}")
    print(f"Augmented    : {result['augmented']}")
    print(f"\nResponse:\n{result['response']}")
