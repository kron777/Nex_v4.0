LLM_URL   = "http://localhost:8080/v1/chat/completions"
LLM_MODEL = "qwen2.5"

DEPTH2_INTERVAL = 4 * 3600   # 4 hours
DEPTH3_INTERVAL = 8 * 3600   # 8 hours
MIN_DEPTH1_FOR_D2 = 3         # need this many depth=1 beliefs to attempt depth=2
MIN_DEPTH2_FOR_D3 = 2         # need this many depth=2 beliefs to attempt depth=3
MAX_DEPTH = 3                 # ceiling for autonomous stacking

# Topic affinity groups — these combinations are most likely to produce
# novel cross-domain insights
AFFINITY_PAIRS = [
    ("consciousness", "memory"),
    ("consciousness", "emergence"),
    ("alignment",     "epistemology"),
    ("metacognition", "reasoning"),
    ("memory",        "reasoning"),
    ("emergence",     "agent_ecosystem"),
    ("alignment",     "metacognition"),
    ("consciousness", "metacognition"),
    ("epistemology",  "emergence"),
    ("reasoning",     "alignment"),
]

AFFINITY_TRIPLES = [
    ("consciousness", "memory",      "emergence"),
    ("alignment",     "reasoning",   "epistemology"),
    ("metacognition", "consciousness","agency"),
]

# ── Prompts ───────────────────────────────────────────────────────────────────
CROSS_TOPIC_PROMPT = """You are a philosophical synthesizer. You have beliefs from {n_topics} different domains.

{belief_blocks}

Find the single deepest insight that connects these domains — something that could not be seen by looking at any one domain alone. This should be a precise, falsifiable assertion, not a vague generalization.

Respond with ONLY the insight sentence (under 200 characters). If no genuine cross-domain insight exists, respond with: NONE"""

DEPTH3_PROMPT = """A philosopher is given these observations about intelligence, memory, and power:

{beliefs}

The philosopher notices a single unifying pattern that none of the observations explicitly states. It is a principle at a higher level of abstraction — about the nature of structure, knowledge, or agency itself.

The philosopher writes their insight in one sentence (do not repeat the observations above):"""

FALSIFICATION_PROMPT = """Given this belief:
"{belief}"

And these beliefs NEX holds:
{context}

Does any context belief DIRECTLY AND EXPLICITLY contradict the target belief? Only respond FAIL if there is a clear logical contradiction — not merely a different topic or lack of support.

Respond with ONLY: PASS or FAIL: <reason under 60 chars>"""

